{
  "name": "playwrightadvanceframework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --grep @ui",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:debug": "npx playwright test --debug",
    "test:e2e": "npx playwright test --grep @e2e",
    "test:p0": "npx playwright test --grep @p0",
    "test:report": "npx playwright show-report",
    "test:p1": "npx playwright test --grep @lor",
    "test:report:ci": "npx playwright test --reporter=html --output=./test-results",
    "lint": "npx eslint . --ext .ts,.js",
    "type-check": "npx tsc --noEmit",
    "verify": "npm run type-check && npm run lint",
    "format": "npx prettier --write .",
    "build": "npx tsc",
    "clean": "rm -rf ./test-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "allure-playwright": "^3.10.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  }
}
